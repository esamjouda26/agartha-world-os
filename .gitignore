# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase — local CLI state, rewritten on every command
supabase/.temp/
supabase/.branches/

# claude code local state
.claude/

# verification artifacts
/lighthouse-report.json
/lighthouse-a11y.json

# session-only working notes (not for the public repo)
/prompt.md
/sessions.md
/lighthouse-phase3.json

/tests
