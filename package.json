{
  "name": "agartha-world-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=1 next build",
    "lighthouse:attendance": "tsx scripts/lighthouse-attendance.ts",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . && eslint --fix .",
    "format:check": "prettier --check . && eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:types": "supabase gen types typescript --linked > src/types/database.ts",
    "prepare": "husky",
    "rbac:domains": "tsx scripts/generate-domain-codes.ts",
    "rbac:verify-urlpattern": "tsx scripts/verify-urlpattern-runtime.ts",
    "rbac:pattern-uniqueness": "tsx scripts/rbac-pattern-uniqueness.ts",
    "rbac:orphan-routes": "tsx scripts/rbac-orphan-routes.ts",
    "rbac:rls-parity": "tsx scripts/rbac-rls-parity.ts",
    "rbac:bundle-budget": "tsx scripts/rbac-bundle-budget.ts",
    "rbac:verify": "pnpm rbac:domains && pnpm rbac:verify-urlpattern && pnpm rbac:pattern-uniqueness && pnpm rbac:orphan-routes && pnpm rbac:rls-parity"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "nuqs": "^2.8.9",
    "pino": "^10.3.1",
    "posthog-node": "^5.29.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@commitlint/cli": "^19.7.0",
    "@commitlint/config-conventional": "^19.7.0",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.18.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@next/eslint-plugin-next": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.18.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
